# AtlasMed Monorepo .gitignore

# ============================================
# Root level
# ============================================
node_modules/
.DS_Store
*.log
*.env
.env.local
.env.*.local

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ============================================
# Backend (Bun + TypeScript + Elysia)
# ============================================
backend/node_modules/
backend/dist/
backend/build/
backend/.env
backend/.env.local
backend/.env.*.local
backend/*.log

# ============================================
# Web (Next.js + React)
# ============================================
web/node_modules/
web/.next/
web/out/
web/build/
web/dist/
web/.env
web/.env.local
web/.env.*.local
web/.vercel
web/*.log

# Next.js specific
web/.next/
web/out/
web/.turbo/

# ============================================
