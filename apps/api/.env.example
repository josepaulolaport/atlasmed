# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
PORT=3000

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/atlasmed

# Database connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379

# Prefix for all Redis keys (useful for multi-tenant or environment separation)
REDIS_KEY_PREFIX=atlasmed:

# ============================================================================
# JWT Configuration
# ============================================================================
# IMPORTANT: Use strong, random secrets in production (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-access-secret-here-min-32-characters-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars-change-in-production

# Token expiration times
# Formats: "15m" (15 minutes), "1h" (1 hour), "7d" (7 days), etc.
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# HMAC pepper for token hashing at rest (min 16 chars). Generate: openssl rand -base64 32
TOKEN_HASH_PEPPER=

# strict = block refresh on IP/UA drift; audit_only = log only (field users / mobile)
SESSION_SECURITY_MODE=strict

# Require verified email before password login
REQUIRE_EMAIL_VERIFIED_FOR_LOGIN=false

# 2FA stub — not implemented
TWO_FACTOR_ENABLED=false

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Primary frontend URL
FRONTEND_URL=http://localhost:3001

# ============================================================================
# External Services - Email
# ============================================================================
# Resend API key for email notifications
RESEND_API_KEY=re_your_resend_api_key_here

# Sender address — must be a verified domain in Resend
# For testing without a custom domain, use: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# External Services - SMS/WhatsApp (Optional)
# ============================================================================
# Twilio credentials for SMS and WhatsApp notifications
# Leave empty to disable SMS/WhatsApp features
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Rate limit window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Security Configuration
# ============================================================================
# Session maximum age in hours
SESSION_MAX_AGE_HOURS=24

# Password reset token expiry in minutes
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60

# Invitation expiry in days
INVITE_EXPIRY_DAYS=7

# Maximum login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes after too many failed attempts
LOGIN_LOCKOUT_MINUTES=15

# ============================================================================
# Observability Configuration (Optional)
# ============================================================================
# Service name for OpenTelemetry
OTEL_SERVICE_NAME=atlasmed-api

# OpenTelemetry endpoints (leave empty to disable)
# Example: http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# Feature Flags
# ============================================================================
# Enable/disable features without code changes
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_AUDIT_LOG=true
