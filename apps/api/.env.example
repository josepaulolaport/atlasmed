NODE_ENV=development

PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlasmed

REDIS_URL=redis://localhost:6379

JWT_SECRET=super-secret

JWT_EXPIRES_IN=7d

# Resend Email Service
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Twilio WhatsApp Service
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Seed Configuration (for initial admin user)
# Change these values and run: cd packages/database && bun run seed
SEED_ADMIN_EMAIL=admin@atlasmed.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_me_in_production
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator