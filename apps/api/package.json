{
  "name": "@atlasmed/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/app/server.ts",
    "start": "bun src/app/server.ts",
    "build": "bun build ./src/app/server.ts --outdir dist",
    "test": "NODE_ENV=test bun test",
    "test:unit": "NODE_ENV=test bun test --test-name-pattern=\"^((?!Integration Tests).)*$\"",
    "test:integration": "NODE_ENV=test bun test --test-name-pattern=\"Integration Tests\"",
    "test:watch": "NODE_ENV=test bun test --watch",
    "lint": "eslint src/app",
    "typecheck": "tsc --noEmit",
    "db:migrate": "cd ../../packages/database && prisma migrate dev",
    "db:migrate:test": "cd ../../packages/database && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlasmed_test prisma migrate deploy",
    "db:studio": "cd ../../packages/database && prisma studio",
    "db:generate": "cd ../../packages/database && prisma generate",
    "db:seed": "bun src/infrastructure/database/seed.ts",
    "db:seed:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlasmed_test bun src/infrastructure/database/test-seed.ts",
    "db:reset:test": "cd ../../packages/database && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlasmed_test prisma migrate reset --force --skip-seed"
  },
  "dependencies": {
    "@atlasmed/access": "workspace:*",
    "@atlasmed/config": "workspace:*",
    "@atlasmed/database": "workspace:*",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "prisma": "^7.8.0",
    "typescript": "^5"
  }
}