{
  "name": "@atlasmed/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/app/server.ts",
    "start": "bun src/app/server.ts",
    "build": "bun build ./src/app/server.ts --outdir dist",
    "test": "bun test",
    "lint": "eslint src/app",
    "typecheck": "tsc --noEmit",
