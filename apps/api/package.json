    "@elysiajs/cors": "^1.4.2",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "^6",
    "typescript": "^5"
  }
