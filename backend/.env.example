# Backend Environment Variables
# Copy this file to .env and fill in your development values
# NEVER commit .env to git - it's in .gitignore

# Server Configuration
PORT=3001
NODE_ENV=development
HOST=localhost

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/atlasmed_dev
DATABASE_POOL_SIZE=10

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# External APIs (if any)
# API_KEY=your-api-key-here

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000

# Production values should be set in:
# - GitHub Secrets for CI/CD
# - Deployment platform (Railway/Fly.io/AWS) for runtime
