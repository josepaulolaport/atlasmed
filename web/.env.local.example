# Web App Environment Variables
# Copy this file to .env.local and fill in your development values
# NEVER commit .env.local to git - it's in .gitignore

# Next.js automatically loads .env.local for local development
# Production values should be set in your deployment platform (Vercel/Netlify)

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_TIMEOUT=10000

# Feature Flags (public variables - prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_APP_ENV=development

# Private Server-Side Variables (no NEXT_PUBLIC_ prefix)
# These are NOT exposed to the browser
API_SECRET_KEY=your-server-side-secret
DATABASE_URL=postgresql://user:password@localhost:5432/atlasmed_dev

# Analytics (if using)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# Production values should be set in:
# - Vercel/Netlify environment variables dashboard
# - Or GitHub Secrets if deploying via GitHub Actions
