model User {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  username             String                    @unique
  phoneNumber          String?                   @unique
  emailVerified        Boolean                   @default(false)
  phoneVerified        Boolean                   @default(false)
  emailVerifiedAt      DateTime?
  phoneVerifiedAt      DateTime?
  passwordHash         String
  passwordHistory      String[]                  @default([])
  firstName            String?
  lastName             String?
  avatarUrl            String?
  status               UserStatus                @default(PENDING)
  tokenVersion         Int                       @default(1)
  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  deactivatedAt        DateTime?
  suspendedAt          DateTime?
  twoFactorEnabled     Boolean                   @default(false)
  twoFactorSecret      String?
  deletedAt            DateTime?
  metadata             Json?
  roleId               String
  role                 Role                      @relation(fields: [roleId], references: [id])
  managerId            String?
  manager              User?                     @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports        User[]                    @relation("UserManager")
  territoryAssignments UserTerritoryAssignment[]
  sessions             Session[]
  passwordResets       PasswordReset[]
  auditLogs            AuditLog[]
  verificationTokens   VerificationToken[]
  sentInvitations      Invitation[]              @relation("InvitedByUser")
  permissions          Permission[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([email])
  @@index([username])
  @@index([phoneNumber])
  @@index([status])
  @@index([deletedAt])
  @@index([managerId])
  @@map("users")
  @@schema("public")
}

model UserTerritoryAssignment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  territoryId String
  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Restrict)
  assignedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, territoryId])
  @@index([userId])
  @@index([territoryId])
  @@map("user_territory_assignments")
  @@schema("public")
}

model TerritoryType {
  id                   String      @id @default(cuid())
  slug                 String      @unique
  name                 String
  description          String?
  canHaveBoundary      Boolean     @default(true)
  assignsClinics       Boolean     @default(false)
  assignableToUsers    Boolean     @default(false)
  assignableToManagers Boolean     @default(false)
  isCountryLevel       Boolean     @default(false)
  blockSiblingOverlap  Boolean     @default(false)
  sortOrder            Int         @default(0)
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  territories          Territory[]

  @@index([isActive])
  @@map("territory_types")
  @@schema("public")
}

model Territory {
  id                     String                           @id @default(cuid())
  name                   String
  slug                   String
  code                   String                           @unique
  nodeType               TerritoryNodeType
  territoryTypeId        String
  territoryType          TerritoryType                    @relation(fields: [territoryTypeId], references: [id], onDelete: Restrict)
  countryCode            String?
  regionSlug             String?
  stateCode              String?
  parentId               String?
  parent                 Territory?                       @relation("TerritoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children               Territory[]                      @relation("TerritoryHierarchy")
  isActive               Boolean                          @default(true)
  parentAssignmentStatus TerritoryParentAssignmentStatus  @default(resolved)
  parentAssignmentSource TerritoryParentAssignmentSource?
  organizationId         String?
  geoMembershipStatus    TerritoryGeoMembershipStatus?
  boundaryMinLng         Float?
  boundaryMinLat         Float?
  boundaryMaxLng         Float?
  boundaryMaxLat         Float?
  boundaryAreaSqKm       Float?
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  facilities                 Facility[]
  userAssignments            UserTerritoryAssignment[]
  closureAsAncestor          TerritoryClosure[]         @relation("ClosureAncestor")
  closureAsDescendant        TerritoryClosure[]         @relation("ClosureDescendant")
  approvalRequests           TerritoryApprovalRequest[] @relation("ApprovalTargetTerritory")
  facilityApprovalRequests   TerritoryApprovalRequest[] @relation("ApprovalFacilityTerritory")
  rollupLinksAsTerritory     TerritoryRollupLink[]      @relation("RollupTerritory")
  rollupLinksAsAncestor      TerritoryRollupLink[]      @relation("RollupAncestor")
  geoMembershipAsOperational TerritoryGeoMembership[]   @relation("GeoMembershipOperational")
  geoMembershipAsReference   TerritoryGeoMembership[]   @relation("GeoMembershipReference")

  @@unique([parentId, name])
  @@unique([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([nodeType])
  @@index([countryCode])
  @@index([parentAssignmentStatus])
  @@index([territoryTypeId])
  @@map("territories")
  @@schema("public")
}

model TerritoryClosure {
  ancestorId   String
  descendantId String
  depth        Int
  ancestor     Territory @relation("ClosureAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant   Territory @relation("ClosureDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@index([descendantId])
  @@map("territory_closure")
  @@schema("public")
}

model TerritoryRollupLink {
  id               String                          @id @default(cuid())
  territoryId      String
  ancestorId       String
  relationshipType TerritoryRollupRelationshipType @default(reporting)
  source           TerritoryRollupLinkSource       @default(manual)
  territory        Territory                       @relation("RollupTerritory", fields: [territoryId], references: [id], onDelete: Cascade)
  ancestor         Territory                       @relation("RollupAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  createdAt        DateTime                        @default(now())

  @@unique([territoryId, ancestorId, relationshipType])
  @@index([ancestorId])
  @@index([territoryId, source])
  @@map("territory_rollup_links")
  @@schema("public")
}

model TerritoryGeoMembership {
  id                     String    @id @default(cuid())
  operationalTerritoryId String
  referenceTerritoryId   String
  referenceTypeSlug      String
  overlapRatio           Float
  intersectionAreaSqKm   Float
  computedAt             DateTime  @default(now())
  operationalTerritory   Territory @relation("GeoMembershipOperational", fields: [operationalTerritoryId], references: [id], onDelete: Cascade)
  referenceTerritory     Territory @relation("GeoMembershipReference", fields: [referenceTerritoryId], references: [id], onDelete: Cascade)

  @@unique([operationalTerritoryId, referenceTerritoryId])
  @@index([referenceTerritoryId])
  @@index([operationalTerritoryId])
  @@map("territory_geo_membership")
  @@schema("public")
}

model TerritoryApprovalRequest {
  id                String                     @id @default(cuid())
  type              TerritoryApprovalType
  status            TerritoryApprovalStatus    @default(pending)
  requesterId       String
  reviewerId        String?
  entityPayload     Json                       @default("{}")
  targetTerritoryId String?
  targetTerritory   Territory?                 @relation("ApprovalTargetTerritory", fields: [targetTerritoryId], references: [id], onDelete: SetNull)
  facilityId        String?
  facility          Facility?                  @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  toTerritoryId     String?
  toTerritory       Territory?                 @relation("ApprovalFacilityTerritory", fields: [toTerritoryId], references: [id], onDelete: SetNull)
  reason            String?
  resolutionNote    String?
  supersededById    String?
  supersededBy      TerritoryApprovalRequest?  @relation("ApprovalSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes        TerritoryApprovalRequest[] @relation("ApprovalSupersession")
  resolvedAt        DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, type])
  @@index([requesterId])
  @@index([targetTerritoryId, status])
  @@index([facilityId, status, type])
  @@map("territory_approval_requests")
  @@schema("public")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  priority    Int          @default(0)
  users       User[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([priority])
  @@map("roles")
  @@schema("public")
}

model Session {
  id                       String                @id @default(cuid())
  userId                   String
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash         String                @unique
  expiresAt                DateTime
  revokedAt                DateTime?
  revokedReason            String?
  revokedByUserId          String?
  replacedBySessionId      String?
  previousRefreshTokenHash String?
  lastSeenAt               DateTime              @default(now())
  userAgent                String?
  browserName              String?
  browserVersion           String?
  osName                   String?
  deviceType               AuthSessionDeviceType @default(UNKNOWN)
  deviceName               String?
  deviceFingerprint        String?
  sessionType              AuthSessionType       @default(WEB)
  ipAddress                String?
  ipCountry                String?
  ipCity                   String?
  suspiciousActivity       Boolean               @default(false)
  lastIpAddress            String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([previousRefreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([sessionType])
  @@index([userId, revokedAt, expiresAt])
  @@index([deviceFingerprint])
  @@index([suspiciousActivity])
  @@map("sessions")
  @@schema("public")
}

model Invitation {
  id               String           @id @default(cuid())
  email            String?
  phoneNumber      String?
  tokenHash        String           @unique
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  resendCount      Int              @default(0)
  lastResendAt     DateTime?
  roleId           String
  role             Role             @relation(fields: [roleId], references: [id])
  invitedByUserId  String
  invitedBy        User             @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([email])
  @@index([phoneNumber])
  @@index([tokenHash])
  @@index([status])
  @@index([status, expiresAt])
  @@index([acceptedByUserId])
  @@index([invitedByUserId])
  @@map("invitations")
  @@schema("public")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, usedAt])
  @@map("password_resets")
  @@schema("public")
}

model AuditLog {
  id           String             @id @default(cuid())
  userId       String?
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType    AuditEventType
  severity     AuditEventSeverity @default(INFO)
  actor        String?
  actorId      String?
  resource     String?
  resourceId   String?
  action       String
  details      Json?
  ipAddress    String?
  userAgent    String?
  sessionId    String?
  outcome      String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime           @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
  @@index([actorId])
  @@index([resourceId])
  @@index([sessionId])
  @@index([severity, createdAt])
  @@map("audit_logs")
  @@schema("public")
}

model VerificationToken {
  id         String                @id @default(cuid())
  userId     String
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       VerificationTokenType
  tokenHash  String                @unique
  newValue   String?
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([type])
  @@index([expiresAt])
  @@index([userId, type, verifiedAt])
  @@map("verification_tokens")
  @@schema("public")
}

model Permission {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   String
  resourceId String?
  action     String
  conditions Json?
  grantedBy  String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, resource, resourceId, action])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([userId, resource])
  @@index([expiresAt])
  @@map("permissions")
  @@schema("public")
}

model Facility {
  id                        String                            @id @default(cuid())
  displayName               String                            @map("name")
  address                   String?
  lat                       Float?
  lng                       Float?
  cnesCode                  String?                           @map("cnes_code")
  legalName                 String?                           @map("legal_name")
  tradeName                 String?                           @map("trade_name")
  streetAddress             String?                           @map("street_address")
  streetNumber              String?                           @map("street_number")
  addressComplement         String?                           @map("address_complement")
  neighborhood              String?
  postalCode                String?                           @map("postal_code")
  phoneNumber               String?                           @map("phone_number")
  faxNumber                 String?                           @map("fax_number")
  email                     String?
  websiteUrl                String?                           @map("website_url")
  taxIdCnpj                 String?                           @map("tax_id_cnpj")
  taxIdCpf                  String?                           @map("tax_id_cpf")
  ownerTaxId                String?                           @map("owner_tax_id")
  facilityTypeCode          String?                           @map("facility_type_code")
  registryDeactivationCode  String?                           @map("registry_deactivation_code")
  isActiveInRegistry        Boolean                           @default(true) @map("is_active_in_registry")
  referenceMunicipalityCode String?                           @map("reference_municipality_code")
  conformityStatus          ConformityStatus                  @default(INCOMPLETE)
  commercialStatus          CommercialStatus?                 @map("commercial_status")
  primarySectorId           String?                           @map("primary_sector_id")
  primarySector             Sector?                           @relation(fields: [primarySectorId], references: [id], onDelete: SetNull)
  imageUrl                  String?                           @map("image_url")
  territoryId               String?
  territory                 Territory?                        @relation(fields: [territoryId], references: [id], onDelete: SetNull)
  territoryAssignmentStatus TerritoryAssignmentStatus         @default(unassigned)
  territoryAssignmentSource TerritoryAssignmentSource         @default(geo)
  sourceProvider            String?
  externalSourceId          String?
  sourceContentHash         String?
  sourceFirstSeenAt         DateTime?
  sourceLastSeenAt          DateTime?
  sourcePresent             Boolean                           @default(false)
  sourceTracked             Boolean                           @default(false)
  manuallyEditedAt          DateTime?
  deletedAt                 DateTime?
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt
  professionalAssociations  FacilityProfessional[]
  representatives           FacilityRepresentative[]
  consultantAssignments     FacilityConsultantAssignment[]
  healthcareProviderShares  FacilityHealthcareProviderShare[]
  conformityRecords         ConformityRecord[]
  ingestionSuggestions      IngestionSuggestion[]
  territoryApprovalRequests TerritoryApprovalRequest[]

  @@unique([sourceProvider, externalSourceId])
  @@unique([sourceProvider, cnesCode])
  @@index([territoryId])
  @@index([deletedAt])
  @@index([displayName])
  @@index([sourceProvider, sourcePresent])
  @@index([territoryAssignmentStatus])
  @@index([primarySectorId])
  @@index([conformityStatus])
  @@map("facilities")
  @@schema("public")
}

model Professional {
  id                    String                 @id @default(cuid())
  firstName             String
  lastName              String
  fullName              String?                @map("full_name")
  socialName            String?                @map("social_name")
  primarySpecialtyLabel String?                @map("primary_specialty_label")
  crmCouncil            String?                @map("crm_council")
  crmNumber             String?                @map("crm_number")
  crmState              String?                @map("crm_state")
  sourceProvider        String?
  externalSourceId      String?
  sourceContentHash     String?
  sourceFirstSeenAt     DateTime?
  sourceLastSeenAt      DateTime?
  sourcePresent         Boolean                @default(false)
  sourceTracked         Boolean                @default(false)
  manuallyEditedAt      DateTime?
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  facilityAssociations  FacilityProfessional[]
  ingestionSuggestions  IngestionSuggestion[]

  @@unique([sourceProvider, externalSourceId])
  @@index([deletedAt])
  @@index([lastName, firstName])
  @@index([sourceProvider, sourcePresent])
  @@map("professionals")
  @@schema("public")
}

model FacilityProfessional {
  id                   String                @id @default(cuid())
  professionalId       String
  professional         Professional          @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  facilityId           String
  facility             Facility              @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  occupationCode       String                @default("LEGACY") @map("occupation_code")
  specialtyLabel       String?               @map("specialty_label")
  employmentTypeCode   String?               @map("employment_type_code")
  sourceOccupationCode String?               @map("source_occupation_code")
  isPrescriber         Boolean               @default(false) @map("is_prescriber")
  isBuyer              Boolean               @default(false) @map("is_buyer")
  isDecisionMaker      Boolean               @default(false) @map("is_decision_maker")
  relationshipLevel    String?               @map("relationship_level")
  sourceActive         Boolean               @default(false)
  sourceFirstSeenAt    DateTime?
  sourceLastSeenAt     DateTime?
  confirmedAt          DateTime?
  confirmedByUserId    String?
  endedAt              DateTime?
  endedByUserId        String?
  endReason            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ingestionSuggestions IngestionSuggestion[]

  @@unique([facilityId, professionalId, occupationCode])
  @@index([professionalId])
  @@index([facilityId])
  @@index([facilityId, sourceActive, endedAt])
  @@index([facilityId, confirmedAt, endedAt])
  @@map("facility_professionals")
  @@schema("public")
}

model FacilityRepresentative {
  id                 String      @id @default(cuid())
  facilityId         String
  facility           Facility    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  representativeName String      @map("representative_name")
  roleTitle          String?     @map("role_title")
  email              String?
  taxId              String?     @map("tax_id")
  contactType        ContactType @default(PROFESSIONAL) @map("contact_type")
  relationshipLevel  String?     @map("relationship_level")
  phone              String?
  notes              String?
  sourceProvider     String?     @map("source_provider")
  externalSourceKey  String?     @map("external_source_key")
  sourceActive       Boolean     @default(false) @map("source_active")
  confirmedAt        DateTime?   @map("confirmed_at")
  confirmedByUserId  String?     @map("confirmed_by_user_id")
  endedAt            DateTime?   @map("ended_at")
  manuallyEditedAt   DateTime?   @map("manually_edited_at")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([facilityId, externalSourceKey])
  @@index([facilityId])
  @@index([facilityId, sourceActive, endedAt])
  @@index([facilityId, confirmedAt, endedAt])
  @@map("facility_representatives")
  @@schema("public")
}

model FacilityConsultantAssignment {
  id               String    @id @default(cuid())
  facilityId       String
  facility         Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  userId           String
  startedAt        DateTime  @default(now()) @map("started_at")
  endedAt          DateTime? @map("ended_at")
  assignedByUserId String?   @map("assigned_by_user_id")
  endReason        String?   @map("end_reason")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([facilityId])
  @@index([userId])
  @@index([facilityId, endedAt])
  @@map("facility_consultant_assignments")
  @@schema("public")
}

model Sector {
  id                     String                  @id @default(cuid())
  slug                   String                  @unique
  name                   String
  isActive               Boolean                 @default(true) @map("is_active")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  products               Product[]
  facilities             Facility[]
  conformityRequirements ConformityRequirement[]

  @@index([isActive])
  @@map("sectors")
  @@schema("public")
}

model Product {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sectorId  String   @map("sector_id")
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectorId])
  @@index([isActive])
  @@map("products")
  @@schema("public")
}

model HealthcareProvider {
  id             String                            @id @default(cuid())
  name           String
  type           HealthcareProviderType
  isActive       Boolean                           @default(true) @map("is_active")
  createdAt      DateTime                          @default(now())
  updatedAt      DateTime                          @updatedAt
  facilityShares FacilityHealthcareProviderShare[]

  @@index([isActive])
  @@map("healthcare_providers")
  @@schema("public")
}

model FacilityHealthcareProviderShare {
  id                   String                        @id @default(cuid())
  facilityId           String                        @map("facility_id")
  facility             Facility                      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  healthcareProviderId String                        @map("healthcare_provider_id")
  healthcareProvider   HealthcareProvider            @relation(fields: [healthcareProviderId], references: [id], onDelete: Restrict)
  sharePercent         Float                         @map("share_percent")
  source               HealthcareProviderShareSource @default(MANUAL)
  sourceFirstSeenAt    DateTime?                     @map("source_first_seen_at")
  sourceLastSeenAt     DateTime?                     @map("source_last_seen_at")
  manuallyEditedAt     DateTime?                     @map("manually_edited_at")
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  @@unique([facilityId, healthcareProviderId])
  @@index([facilityId])
  @@index([healthcareProviderId])
  @@map("facility_healthcare_provider_shares")
  @@schema("public")
}

model ConformityRequirement {
  id          String             @id @default(cuid())
  slug        String             @unique
  name        String
  description String?
  sectorId    String?            @map("sector_id")
  sector      Sector?            @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  records     ConformityRecord[]

  @@index([sectorId])
  @@index([isActive])
  @@map("conformity_requirements")
  @@schema("public")
}

model ConformityRecord {
  id                String                 @id @default(cuid())
  facilityId        String                 @map("facility_id")
  facility          Facility               @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  requirementId     String                 @map("requirement_id")
  requirement       ConformityRequirement  @relation(fields: [requirementId], references: [id], onDelete: Restrict)
  status            ConformityRecordStatus @default(PENDING)
  submittedAt       DateTime?              @map("submitted_at")
  validatedAt       DateTime?              @map("validated_at")
  expiresAt         DateTime?              @map("expires_at")
  validatedByUserId String?                @map("validated_by_user_id")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([facilityId, requirementId])
  @@index([facilityId])
  @@index([requirementId])
  @@index([status])
  @@map("conformity_records")
  @@schema("public")
}

model IngestionRun {
  id             String                @id @default(cuid())
  sourceProvider String
  status         IngestionRunStatus    @default(RUNNING)
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  stats          Json?
  error          String?
  suggestions    IngestionSuggestion[]

  @@index([sourceProvider, startedAt])
  @@index([status])
  @@map("ingestion_runs")
  @@schema("public")
}

model IngestionSuggestion {
  id                     String                    @id @default(cuid())
  ingestionRunId         String
  ingestionRun           IngestionRun              @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)
  type                   IngestionSuggestionType
  status                 IngestionSuggestionStatus @default(PENDING)
  facilityId             String?
  facility               Facility?                 @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  professionalId         String?
  professional           Professional?             @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  facilityProfessionalId String?
  facilityProfessional   FacilityProfessional?     @relation(fields: [facilityProfessionalId], references: [id], onDelete: SetNull)
  reason                 String?
  payload                Json                      @default("{}")
  suggestedAt            DateTime                  @default(now())
  resolvedAt             DateTime?
  resolvedByUserId       String?
  resolutionNote         String?

  @@index([status, type])
  @@index([facilityId, status])
  @@index([ingestionRunId])
  @@map("ingestion_suggestions")
  @@schema("public")
}
