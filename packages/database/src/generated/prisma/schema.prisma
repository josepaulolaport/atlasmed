// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum AuthSessionDeviceType {
  DESKTOP
  MOBILE
  TABLET
  UNKNOWN
}

enum AuthSessionType {
  WEB
  MOBILE
  API
}

enum AuditEventType {
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  USER_INVITE
  USER_ACCEPT_INVITE
  USER_DEACTIVATE
  USER_ACTIVATE
  USER_SUSPEND
  USER_UNSUSPEND
  USER_MANAGER_ASSIGNED
  USER_MANAGER_REMOVED
  USER_TERRITORY_ASSIGNED
  USER_TERRITORY_REVOKED
  PASSWORD_CHANGE
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  EMAIL_CHANGE
  PHONE_CHANGE
  EMAIL_VERIFY
  PHONE_VERIFY
  ROLE_CHANGE
  SESSION_CREATE
  SESSION_REVOKE
  PERMISSION_GRANT
  PERMISSION_REVOKE
  TWO_FACTOR_ENABLE
  TWO_FACTOR_DISABLE
  SUSPICIOUS_ACTIVITY
  DATA_ACCESS
  DATA_EXPORT
  REGISTRY_INGESTION_COMPLETED
  REGISTRY_SUGGESTION_APPROVED
  REGISTRY_SUGGESTION_REJECTED
  DOCTOR_CLINIC_CONFIRMED
  DOCTOR_CLINIC_ASSOCIATION_ENDED
  DOCTOR_CLINIC_MANUAL_ASSOCIATED
  CLINIC_REACTIVATED
}

enum IngestionRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum IngestionSuggestionType {
  CLINIC_REMOVAL
  CLINIC_REACTIVATION
  DOCTOR_CLINIC_REMOVAL
}

enum IngestionSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  SUPERSEDED
}

enum AuditEventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  EMAIL_CHANGE
  PHONE_CHANGE
}

enum TerritoryNodeType {
  root
  region
  state
  intermediate
  patch
}

enum TerritoryRollupRelationshipType {
  reporting
}

enum TerritoryRollupLinkSource {
  geo
  manual
}

enum TerritoryParentAssignmentStatus {
  resolved
  ambiguous
  manual
}

enum TerritoryParentAssignmentSource {
  geo
  inferred
  manual
}

enum TerritoryGeoMembershipStatus {
  pending
  ready
  failed
}

enum TerritoryAssignmentStatus {
  assigned
  unassigned
  ambiguous
}

enum TerritoryAssignmentSource {
  geo
  manual
}

enum TerritoryApprovalType {
  create_territory
  reparent_territory
  deactivate_territory
  clinic_territory_change
}

enum TerritoryApprovalStatus {
  pending
  approved
  rejected
  superseded
}

model User {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  username             String                    @unique
  phoneNumber          String?                   @unique
  emailVerified        Boolean                   @default(false)
  phoneVerified        Boolean                   @default(false)
  emailVerifiedAt      DateTime?
  phoneVerifiedAt      DateTime?
  passwordHash         String
  passwordHistory      String[]                  @default([])
  firstName            String?
  lastName             String?
  avatarUrl            String?
  status               UserStatus                @default(PENDING)
  tokenVersion         Int                       @default(1)
  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  deactivatedAt        DateTime?
  suspendedAt          DateTime?
  twoFactorEnabled     Boolean                   @default(false)
  twoFactorSecret      String?
  deletedAt            DateTime?
  metadata             Json?
  roleId               String
  role                 Role                      @relation(fields: [roleId], references: [id])
  managerId            String?
  manager              User?                     @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports        User[]                    @relation("UserManager")
  territoryAssignments UserTerritoryAssignment[]
  sessions             Session[]
  passwordResets       PasswordReset[]
  auditLogs            AuditLog[]
  verificationTokens   VerificationToken[]
  sentInvitations      Invitation[]              @relation("InvitedByUser")
  permissions          Permission[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([email])
  @@index([username])
  @@index([phoneNumber])
  @@index([status])
  @@index([deletedAt])
  @@index([managerId])
  @@map("users")
}

model UserTerritoryAssignment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  territoryId String
  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Restrict)
  assignedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, territoryId])
  @@index([userId])
  @@index([territoryId])
  @@map("user_territory_assignments")
}

model TerritoryType {
  id                   String      @id @default(cuid())
  slug                 String      @unique
  name                 String
  description          String?
  canHaveBoundary      Boolean     @default(true)
  assignsClinics       Boolean     @default(false)
  assignableToUsers    Boolean     @default(false)
  assignableToManagers Boolean     @default(false)
  isCountryLevel       Boolean     @default(false)
  blockSiblingOverlap  Boolean     @default(false)
  sortOrder            Int         @default(0)
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  territories          Territory[]

  @@index([isActive])
  @@map("territory_types")
}

model Territory {
  id                     String                           @id @default(cuid())
  name                   String
  slug                   String
  code                   String                           @unique
  nodeType               TerritoryNodeType
  territoryTypeId        String
  territoryType          TerritoryType                    @relation(fields: [territoryTypeId], references: [id], onDelete: Restrict)
  countryCode            String?
  regionSlug             String?
  stateCode              String?
  parentId               String?
  parent                 Territory?                       @relation("TerritoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children               Territory[]                      @relation("TerritoryHierarchy")
  isActive               Boolean                          @default(true)
  parentAssignmentStatus TerritoryParentAssignmentStatus  @default(resolved)
  parentAssignmentSource TerritoryParentAssignmentSource?
  organizationId         String?
  geoMembershipStatus    TerritoryGeoMembershipStatus?
  boundaryMinLng         Float?
  boundaryMinLat         Float?
  boundaryMaxLng         Float?
  boundaryMaxLat         Float?
  boundaryAreaSqKm       Float?
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  clinics                    Clinic[]
  userAssignments            UserTerritoryAssignment[]
  closureAsAncestor          TerritoryClosure[]         @relation("ClosureAncestor")
  closureAsDescendant        TerritoryClosure[]         @relation("ClosureDescendant")
  approvalRequests           TerritoryApprovalRequest[] @relation("ApprovalTargetTerritory")
  clinicApprovalRequests     TerritoryApprovalRequest[] @relation("ApprovalClinicTerritory")
  rollupLinksAsTerritory     TerritoryRollupLink[]      @relation("RollupTerritory")
  rollupLinksAsAncestor      TerritoryRollupLink[]      @relation("RollupAncestor")
  geoMembershipAsOperational TerritoryGeoMembership[]   @relation("GeoMembershipOperational")
  geoMembershipAsReference   TerritoryGeoMembership[]   @relation("GeoMembershipReference")

  @@unique([parentId, name])
  @@unique([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([nodeType])
  @@index([countryCode])
  @@index([parentAssignmentStatus])
  @@index([territoryTypeId])
  @@map("territories")
}

model TerritoryClosure {
  ancestorId   String
  descendantId String
  depth        Int
  ancestor     Territory @relation("ClosureAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant   Territory @relation("ClosureDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@index([descendantId])
  @@map("territory_closure")
}

model TerritoryRollupLink {
  id               String                          @id @default(cuid())
  territoryId      String
  ancestorId       String
  relationshipType TerritoryRollupRelationshipType @default(reporting)
  source           TerritoryRollupLinkSource       @default(manual)
  territory        Territory                       @relation("RollupTerritory", fields: [territoryId], references: [id], onDelete: Cascade)
  ancestor         Territory                       @relation("RollupAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  createdAt        DateTime                        @default(now())

  @@unique([territoryId, ancestorId, relationshipType])
  @@index([ancestorId])
  @@index([territoryId, source])
  @@map("territory_rollup_links")
}

model TerritoryGeoMembership {
  id                     String    @id @default(cuid())
  operationalTerritoryId String
  referenceTerritoryId   String
  referenceTypeSlug      String
  overlapRatio           Float
  intersectionAreaSqKm   Float
  computedAt             DateTime  @default(now())
  operationalTerritory   Territory @relation("GeoMembershipOperational", fields: [operationalTerritoryId], references: [id], onDelete: Cascade)
  referenceTerritory     Territory @relation("GeoMembershipReference", fields: [referenceTerritoryId], references: [id], onDelete: Cascade)

  @@unique([operationalTerritoryId, referenceTerritoryId])
  @@index([referenceTerritoryId])
  @@index([operationalTerritoryId])
  @@map("territory_geo_membership")
}

model TerritoryApprovalRequest {
  id                String                     @id @default(cuid())
  type              TerritoryApprovalType
  status            TerritoryApprovalStatus    @default(pending)
  requesterId       String
  reviewerId        String?
  entityPayload     Json                       @default("{}")
  targetTerritoryId String?
  targetTerritory   Territory?                 @relation("ApprovalTargetTerritory", fields: [targetTerritoryId], references: [id], onDelete: SetNull)
  clinicId          String?
  clinic            Clinic?                    @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  toTerritoryId     String?
  toTerritory       Territory?                 @relation("ApprovalClinicTerritory", fields: [toTerritoryId], references: [id], onDelete: SetNull)
  reason            String?
  resolutionNote    String?
  supersededById    String?
  supersededBy      TerritoryApprovalRequest?  @relation("ApprovalSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes        TerritoryApprovalRequest[] @relation("ApprovalSupersession")
  resolvedAt        DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, type])
  @@index([requesterId])
  @@index([targetTerritoryId, status])
  @@index([clinicId, status, type])
  @@map("territory_approval_requests")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  priority    Int          @default(0)
  users       User[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([priority])
  @@map("roles")
}

model Session {
  id                       String                @id @default(cuid())
  userId                   String
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash         String                @unique
  expiresAt                DateTime
  revokedAt                DateTime?
  revokedReason            String?
  revokedByUserId          String?
  replacedBySessionId      String?
  previousRefreshTokenHash String?
  lastSeenAt               DateTime              @default(now())
  userAgent                String?
  browserName              String?
  browserVersion           String?
  osName                   String?
  deviceType               AuthSessionDeviceType @default(UNKNOWN)
  deviceName               String?
  deviceFingerprint        String?
  sessionType              AuthSessionType       @default(WEB)
  ipAddress                String?
  ipCountry                String?
  ipCity                   String?
  suspiciousActivity       Boolean               @default(false)
  lastIpAddress            String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([previousRefreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([sessionType])
  @@index([userId, revokedAt, expiresAt])
  @@index([deviceFingerprint])
  @@index([suspiciousActivity])
  @@map("sessions")
}

model Invitation {
  id               String           @id @default(cuid())
  email            String?
  phoneNumber      String?
  tokenHash        String           @unique
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  resendCount      Int              @default(0)
  lastResendAt     DateTime?
  roleId           String
  role             Role             @relation(fields: [roleId], references: [id])
  invitedByUserId  String
  invitedBy        User             @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([email])
  @@index([phoneNumber])
  @@index([tokenHash])
  @@index([status])
  @@index([status, expiresAt])
  @@index([acceptedByUserId])
  @@index([invitedByUserId])
  @@map("invitations")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, usedAt])
  @@map("password_resets")
}

model AuditLog {
  id           String             @id @default(cuid())
  userId       String?
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType    AuditEventType
  severity     AuditEventSeverity @default(INFO)
  actor        String?
  actorId      String?
  resource     String?
  resourceId   String?
  action       String
  details      Json?
  ipAddress    String?
  userAgent    String?
  sessionId    String?
  outcome      String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime           @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
  @@index([actorId])
  @@index([resourceId])
  @@index([sessionId])
  @@index([severity, createdAt])
  @@map("audit_logs")
}

model VerificationToken {
  id         String                @id @default(cuid())
  userId     String
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       VerificationTokenType
  tokenHash  String                @unique
  newValue   String?
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([type])
  @@index([expiresAt])
  @@index([userId, type, verifiedAt])
  @@map("verification_tokens")
}

model Permission {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   String
  resourceId String?
  action     String
  conditions Json?
  grantedBy  String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, resource, resourceId, action])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([userId, resource])
  @@index([expiresAt])
  @@map("permissions")
}

model Clinic {
  id                        String                     @id @default(cuid())
  name                      String
  address                   String?
  lat                       Float?
  lng                       Float?
  territoryId               String?
  territory                 Territory?                 @relation(fields: [territoryId], references: [id], onDelete: SetNull)
  territoryAssignmentStatus TerritoryAssignmentStatus  @default(unassigned)
  territoryAssignmentSource TerritoryAssignmentSource  @default(geo)
  sourceProvider            String?
  externalSourceId          String?
  sourceContentHash         String?
  sourceFirstSeenAt         DateTime?
  sourceLastSeenAt          DateTime?
  sourcePresent             Boolean                    @default(false)
  sourceTracked             Boolean                    @default(false)
  manuallyEditedAt          DateTime?
  deletedAt                 DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  doctorAssociations        DoctorClinicAssociation[]
  ingestionSuggestions      IngestionSuggestion[]
  territoryApprovalRequests TerritoryApprovalRequest[]

  @@unique([sourceProvider, externalSourceId])
  @@index([territoryId])
  @@index([deletedAt])
  @@index([name])
  @@index([sourceProvider, sourcePresent])
  @@index([territoryAssignmentStatus])
  @@map("clinics")
}

model Doctor {
  id                   String                    @id @default(cuid())
  firstName            String
  lastName             String
  specialty            String?
  sourceProvider       String?
  externalSourceId     String?
  sourceContentHash    String?
  sourceFirstSeenAt    DateTime?
  sourceLastSeenAt     DateTime?
  sourcePresent        Boolean                   @default(false)
  sourceTracked        Boolean                   @default(false)
  manuallyEditedAt     DateTime?
  deletedAt            DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  clinicAssociations   DoctorClinicAssociation[]
  ingestionSuggestions IngestionSuggestion[]

  @@unique([sourceProvider, externalSourceId])
  @@index([deletedAt])
  @@index([lastName, firstName])
  @@index([sourceProvider, sourcePresent])
  @@map("doctors")
}

model DoctorClinicAssociation {
  id                   String                @id @default(cuid())
  doctorId             String
  doctor               Doctor                @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicId             String
  clinic               Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  sourceActive         Boolean               @default(false)
  sourceFirstSeenAt    DateTime?
  sourceLastSeenAt     DateTime?
  confirmedAt          DateTime?
  confirmedByUserId    String?
  endedAt              DateTime?
  endedByUserId        String?
  endReason            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ingestionSuggestions IngestionSuggestion[]

  @@unique([doctorId, clinicId])
  @@index([doctorId])
  @@index([clinicId])
  @@index([clinicId, sourceActive, endedAt])
  @@index([clinicId, confirmedAt, endedAt])
  @@map("doctor_clinic_associations")
}

model IngestionRun {
  id             String                @id @default(cuid())
  sourceProvider String
  status         IngestionRunStatus    @default(RUNNING)
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  stats          Json?
  error          String?
  suggestions    IngestionSuggestion[]

  @@index([sourceProvider, startedAt])
  @@index([status])
  @@map("ingestion_runs")
}

model IngestionSuggestion {
  id               String                    @id @default(cuid())
  ingestionRunId   String
  ingestionRun     IngestionRun              @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)
  type             IngestionSuggestionType
  status           IngestionSuggestionStatus @default(PENDING)
  clinicId         String?
  clinic           Clinic?                   @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  doctorId         String?
  doctor           Doctor?                   @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  associationId    String?
  association      DoctorClinicAssociation?  @relation(fields: [associationId], references: [id], onDelete: SetNull)
  reason           String?
  payload          Json                      @default("{}")
  suggestedAt      DateTime                  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?

  @@index([status, type])
  @@index([clinicId, status])
  @@index([ingestionRunId])
  @@map("ingestion_suggestions")
}
