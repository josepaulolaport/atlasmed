# Mobile App Environment Variables
# For Flutter, you'll need to use flutter_dotenv or similar package
# Copy values to a .env file (gitignored) for development

# API Configuration
API_BASE_URL=http://localhost:3001
API_TIMEOUT=10000

# Feature Flags
ENABLE_ANALYTICS=false
APP_ENV=development

# For production, you have several options:
# 1. Use --dart-define during build: flutter build apk --dart-define=API_BASE_URL=https://api.prod.com
# 2. Use flutter_dotenv with different .env files
# 3. Store in CI/CD secrets and inject during build
# 4. Use Firebase Remote Config for runtime configuration

# Never commit sensitive values. For production builds:
# - Store secrets in GitHub Secrets
# - Inject via --dart-define in CI/CD workflow
# - Or use a secrets management service
